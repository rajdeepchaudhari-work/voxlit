{
  "name": "voxlit",
  "productName": "Voxlit",
  "version": "2.0.0",
  "description": "Privacy-first, open-source macOS voice transcription app",
  "main": "out/main/index.js",
  "author": "Voxlit Contributors",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/rajdeepchaudhari-work/voxlit.git"
  },
  "scripts": {
    "dev": "electron-vite dev",
    "reset": "./scripts/reset-dev.sh",
    "dev:fresh": "./scripts/reset-dev.sh && electron-vite dev",
    "build": "electron-vite build",
    "build:mac": "electron-vite build && node scripts/stage-build.js && electron-builder --mac --arm64 --config electron-builder.config.js && node scripts/patch-resources.js",
    "release": "node scripts/release.js",
    "release:homebrew": "node scripts/release-homebrew.js",
    "release:all": "node scripts/release.js && node scripts/release-homebrew.js",
    "build:native": "./scripts/build-native.sh",
    "build:whisper": "./scripts/build-whisper.sh",
    "preview": "electron-vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "lint": "eslint . --ext .ts,.tsx",
    "lint:fix": "eslint . --ext .ts,.tsx --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx src/main/db/migrate.ts",
    "typecheck": "tsc --noEmit -p tsconfig.node.json && tsc --noEmit -p tsconfig.web.json",
    "postinstall": "electron-rebuild -f -w better-sqlite3"
  },
  "dependencies": {
    "better-sqlite3": "^12.8.0"
  },
  "devDependencies": {
    "electron-updater": "^6.8.3",
    "@electron/rebuild": "^4.0.3",
    "@types/better-sqlite3": "^7.6.11",
    "@types/node": "^25.6.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "@vitejs/plugin-react": "^4.3.3",
    "autoprefixer": "^10.4.20",
    "drizzle-kit": "^0.30.0",
    "drizzle-orm": "^0.45.0",
    "electron": "^41.1.1",
    "electron-builder": "^25.1.8",
    "electron-store": "8.2.0",
    "electron-vite": "^2.3.0",
    "eslint": "^8.57.0",
    "eslint-plugin-react": "^7.37.2",
    "eslint-plugin-react-hooks": "^4.6.2",
    "postcss": "^8.4.49",
    "prettier": "^3.4.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8",
    "zustand": "^5.0.0"
  }
}
